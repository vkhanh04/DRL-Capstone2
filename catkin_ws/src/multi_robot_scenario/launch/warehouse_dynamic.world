<sdf version='1.6'>
  <world name='warehouse_dynamic'>

    <light name='sun' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.5 -1</direction>
    </light>

    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <surface><friction><ode><mu>100</mu><mu2>50</mu2></ode></friction></surface>
        </collision>
        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <gravity>0 0 -9.8</gravity>
    <physics name='default_physics' default='0' type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>1</shadows>
    </scene>

    <!-- ═══════════════════════════════════════════
         OUTER WALLS — 10x10m (giống warehouse tĩnh)
         Walls tại ±5.0 m, dày 0.2 m, cao 1.0 m
    ═══════════════════════════════════════════ -->
    <model name='outer_walls'>
      <static>1</static>
      <pose>0 0 0 0 0 0</pose>

      <link name='wall_north'><pose>0 5.0 0.5 0 0 0</pose>
        <visual name='v'><geometry><box><size>10.4 0.2 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Bricks</name></script></material></visual>
        <collision name='c'><geometry><box><size>10.4 0.2 1.0</size></box></geometry></collision>
      </link>

      <link name='wall_south'><pose>0 -5.0 0.5 0 0 0</pose>
        <visual name='v'><geometry><box><size>10.4 0.2 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Bricks</name></script></material></visual>
        <collision name='c'><geometry><box><size>10.4 0.2 1.0</size></box></geometry></collision>
      </link>

      <link name='wall_east'><pose>5.0 0 0.5 0 0 0</pose>
        <visual name='v'><geometry><box><size>0.2 10.0 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Bricks</name></script></material></visual>
        <collision name='c'><geometry><box><size>0.2 10.0 1.0</size></box></geometry></collision>
      </link>

      <link name='wall_west'><pose>-5.0 0 0.5 0 0 0</pose>
        <visual name='v'><geometry><box><size>0.2 10.0 1.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Bricks</name></script></material></visual>
        <collision name='c'><geometry><box><size>0.2 10.0 1.0</size></box></geometry></collision>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════
         KỆ HÀNG TĨNH — giống hệt warehouse.world
         4 kệ 1.8x0.25x0.8m, xen kẽ ngang/dọc
    ═══════════════════════════════════════════ -->

    <!-- Kệ A: tây bắc, nằm ngang -->
    <model name='shelf_a'>
      <static>1</static><pose>-2.8 3.1 0.4 0 0 0</pose>
      <link name='link'>
        <visual name='v'><geometry><box><size>1.8 0.25 0.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/WoodFloor</name></script></material></visual>
        <collision name='c'><geometry><box><size>1.8 0.25 0.8</size></box></geometry></collision>
      </link>
    </model>

    <!-- Kệ B: đông bắc, nằm dọc -->
    <model name='shelf_b'>
      <static>1</static><pose>3.3 2.2 0.4 0 0 1.5708</pose>
      <link name='link'>
        <visual name='v'><geometry><box><size>1.8 0.25 0.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/WoodFloor</name></script></material></visual>
        <collision name='c'><geometry><box><size>1.8 0.25 0.8</size></box></geometry></collision>
      </link>
    </model>

    <!-- Kệ C: giữa tây, nằm ngang -->
    <model name='shelf_c'>
      <static>1</static><pose>-1.5 -1.2 0.4 0 0 0</pose>
      <link name='link'>
        <visual name='v'><geometry><box><size>1.8 0.25 0.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/WoodFloor</name></script></material></visual>
        <collision name='c'><geometry><box><size>1.8 0.25 0.8</size></box></geometry></collision>
      </link>
    </model>

    <!-- Kệ D: đông nam, nằm dọc -->
    <model name='shelf_d'>
      <static>1</static><pose>2.6 -3.0 0.4 0 0 1.5708</pose>
      <link name='link'>
        <visual name='v'><geometry><box><size>1.8 0.25 0.8</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/WoodFloor</name></script></material></visual>
        <collision name='c'><geometry><box><size>1.8 0.25 0.8</size></box></geometry></collision>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════
         CARDBOARD BOXES TĨNH — 7 hộp rải rác
         (giống warehouse.world, env.py random lại mỗi episode)
    ═══════════════════════════════════════════ -->
    <model name='cardboard_box_0'>
      <pose>2.1 4.0 0.149 0 0 0.4</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_1'>
      <pose>-0.8 0.9 0.149 0 0 1.1</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_2'>
      <pose>1.4 -3.6 0.149 0 0 2.3</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_3'>
      <pose>-3.7 -1.8 0.149 0 0 0.8</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_4'>
      <pose>0.3 2.6 0.149 0 0 1.7</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_5'>
      <pose>4.0 -0.7 0.149 0 0 0.3</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <model name='cardboard_box_6'>
      <pose>-4.2 1.5 0.149 0 0 2.8</pose>
      <link name='link'>
        <inertial><mass>2.0</mass>
          <inertia><ixx>0.0267</ixx><ixy>0</ixy><ixz>0</ixz>
                   <iyy>0.0267</iyy><iyz>0</iyz><izz>0.0267</izz></inertia>
        </inertial>
        <collision name='collision'><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction>
          <contact><ode><kp>1e+07</kp><kd>1</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact></surface>
        </collision>
        <visual name='visual'><pose>0 0 -0.15 0 0 0</pose>
          <geometry><mesh><uri>model://cardboard_box/meshes/cardboard_box.dae</uri><scale>1 1 1</scale></mesh></geometry>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════
         DYNAMIC OBSTACLES — 3 trụ di động
         Dùng prismatic joint + librotating_wall_plugin
         (cùng cơ chế Kitchen_collision.world)

         Đặt trong hành lang thoáng để:
         - Không va chạm với kệ tĩnh
         - Không chặn hết lối đi
         - Robot có không gian học cách né

         moving_red  : đi NGANG, y = -3.5, x ∈ [-3.5 → 1.5]  (hành lang nam)
         moving_blue : đi DỌC,   x =  1.5, y ∈ [-2.5 → 3.5]  (hành lang đông)
         moving_green: đi NGANG, y =  1.5, x ∈ [-4.0 → 0.5]  (hành lang tây-giữa)

         amplitude = nửa khoảng di chuyển
         speed     = 0.4 m/s (nhanh hơn Kitchen một chút vì map nhỏ hơn)
    ═══════════════════════════════════════════ -->

    <!-- Trụ đỏ: đi NGANG trên y=-3.5 -->
    <model name='moving_red'>
      <pose>-1.0 -3.5 0.5 0 0 0</pose>
      <link name='body'>
        <visual name='visual'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Red</name></script></material>
        </visual>
        <collision name='collision'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
        </collision>
      </link>
      <joint name='red_joint' type='prismatic'>
        <parent>world</parent>
        <child>body</child>
        <axis><xyz>1 0 0</xyz></axis>
        <limit><lower>-3.5</lower><upper>1.5</upper></limit>
      </joint>
      <plugin name='red_mover' filename='librotating_wall_plugin.so'>
        <joint_name>red_joint</joint_name>
        <amplitude>2.5</amplitude>
        <speed>0.4</speed>
      </plugin>
    </model>

    <!-- Trụ xanh dương: đi DỌC trên x=1.5 -->
    <model name='moving_blue'>
      <pose>1.5 0.5 0.5 0 0 0</pose>
      <link name='body'>
        <visual name='visual'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Blue</name></script></material>
        </visual>
        <collision name='collision'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
        </collision>
      </link>
      <joint name='blue_joint' type='prismatic'>
        <parent>world</parent>
        <child>body</child>
        <axis><xyz>0 1 0</xyz></axis>
        <limit><lower>-2.5</lower><upper>3.5</upper></limit>
      </joint>
      <plugin name='blue_mover' filename='librotating_wall_plugin.so'>
        <joint_name>blue_joint</joint_name>
        <amplitude>3.0</amplitude>
        <speed>0.4</speed>
      </plugin>
    </model>

    <!-- Trụ xanh lá: đi NGANG trên y=1.5 -->
    <model name='moving_green'>
      <pose>-1.75 1.5 0.5 0 0 0</pose>
      <link name='body'>
        <visual name='visual'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Green</name></script></material>
        </visual>
        <collision name='collision'>
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
        </collision>
      </link>
      <joint name='green_joint' type='prismatic'>
        <parent>world</parent>
        <child>body</child>
        <axis><xyz>1 0 0</xyz></axis>
        <limit><lower>-4.0</lower><upper>0.5</upper></limit>
      </joint>
      <plugin name='green_mover' filename='librotating_wall_plugin.so'>
        <joint_name>green_joint</joint_name>
        <amplitude>2.25</amplitude>
        <speed>0.35</speed>
      </plugin>
    </model>

    <!-- ═══ CAMERA top-down ═══ -->
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose>0 0 28 0 1.5708 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

  </world>
</sdf>
